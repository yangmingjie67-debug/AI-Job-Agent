# DeepSeek API configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Flask session signing key. Use a long random value in production.
FLASK_SECRET_KEY=replace_with_a_random_secret_key

# Optional. Defaults to mj_ai.db in the project directory.
DATABASE_PATH=mj_ai.db

# Render: set both paths under the attached Persistent Disk mount.
KNOWLEDGE_BASE_DIRECTORY=/var/data/documents
CHROMA_PERSIST_DIRECTORY=/var/data/chroma_db
CHROMA_COLLECTION_NAME=job_agent_knowledge
